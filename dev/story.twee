:: StoryTitle
Spindle Test Story

:: StoryData
{
  "ifid": "A1B2C3D4-E5F6-4890-ABCD-EF1234567890",
  "format": "spindle",
  "format-version": "0.1.0",
  "start": "Start"
}

:: StoryVariables
$player = { name: "Adventurer", hp: 100, maxHp: 100, strength: 5, dexterity: 5, intelligence: 5, level: 1 }
$inventory = ["rusty key", "torch"]
$visited_rooms = 0
$has_key = false
$has_note = false
$count = 0
$demo_ran = false
$theme = "dark"
$weapon = "sword"
$difficulty = "normal"
$stance = "balanced"
$notes = ""
$accept_terms = false
$username = ""
$age = 0
$unset_test = ""
$repeat_count = 0
$goto_landed = false
$special_name = ""
$html_like = ""
$with_at = ""
$with_underscore = ""
$multi_word = ""
$storyVar = ""
$dynId = ""
$forBtnCount = 0
$unset_a = ""
$unset_b = ""


:: StoryInit
{do}
class Player {
  constructor(data) { Object.assign(this, data); }
  damage(amount) { this.hp = Math.max(0, this.hp - amount); }
  heal(amount) { this.hp = Math.min(this.maxHp, this.hp + amount); }
  get isDead() { return this.hp <= 0; }
  get healthStatus() {
    if (this.hp >= this.maxHp) return "Full health";
    if (this.hp >= 50) return "Doing okay";
    if (this.hp > 0) return "Need healing";
    return "Dead";
  }
}
Story.registerClass('Player', Player);
$player = new Player($player);
{/do}
{set $inventory = ["rusty key", "torch"]}
{set $visited_rooms = 0}
{set $has_key = false}
{set $has_note = false}
{set $count = 0}


:: Start
Welcome, {$player.name}! Your health is {$player.hp}/{$player.maxHp}. Your Strength is {$player.strength}.

A wooden door stands to the north. Through a crack beneath it, you see flickering light.

{if $has_key}
  The rusty key weighs heavy in your pocket.

{/if}

[[Open the door|Hallway]]

[[Look around the room|Room]]

[[Test macros->Macro Demo]] | [[Markdown demo->Markdown Demo]]

[[Widget demo->Widget Demo]] | [[Extra macros->Extra Macros]] | [[Form inputs->Form Inputs]] | [[Interpolation->Interpolation Demo]]

