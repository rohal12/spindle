    "zustand": "^5.0.0",
    "immer": "^10.1.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.7.0",
    "playwright": "^1.58.2",
    "tweenode": "^0.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^4.0.18"
  }
}
